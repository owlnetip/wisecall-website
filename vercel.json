{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/estate-agents",
      "destination": "/property",
      "permanent": true
    },
    {
      "source": "/care-homes",
      "destination": "/industries/care-homes/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
