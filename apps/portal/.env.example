NEXT_PUBLIC_APP_URL=https://app.wisecall.io
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
WISECALL_DEMO_CALLBACK_ENDPOINT=https://your-project.supabase.co/functions/v1/wisecall-demo-callback
WISECALL_DEMO_SMS_WEBHOOK_URL=https://your-sms-webhook.example.com

# Stripe billing (7-day free trial on all plans)
STRIPE_SECRET_KEY=sk_live_or_sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Shared secret for trial reminder + trial-cap edge functions (must match Supabase + DB config)
WISECALL_TRIAL_REMINDER_SECRET=replace-with-random-secret
# Optional overrides — default to the live plan prices/VAT rate (see src/lib/stripe.ts).
# Point these at test-mode duplicates for local development.
# STRIPE_CORE_PRICE=price_...
# STRIPE_GROWTH_PRICE=price_...
# STRIPE_PRO_PRICE=price_...
# STRIPE_VAT_RATE=txr_...
# Email channel add-on (£79/mo) — create in Stripe dashboard, then paste price id:
# STRIPE_EMAIL_CHANNEL_PRICE=price_...
